{
  "certified": false,
  "components": {
    "frontend": {
      "backend_role": "api_routes",
      "browser_verify": {
        "notes": "React SSR/CSR hybrid: no Angular testability API. Wait = domcontentloaded + fixed settle + optional selector wait; path-routed (not hash), so route probes must use real paths or in-app nav.",
        "wait_strategy": "network_settle"
      },
      "commands": {
        "build": "npx next build",
        "serve_dev": "npx next dev"
      },
      "display_name": "Next.js 15 (App Router)",
      "fingerprint_files": [
        "next.config.js",
        "next.config.mjs",
        "next.config.ts"
      ],
      "fullstack_capable": true,
      "id": "nextjs",
      "kind": "frontend",
      "prompt_fragment": "stacks/nextjs-fullstack/ui_agent.md",
      "root_candidates": [
        "frontend",
        "web",
        "."
      ],
      "schema_version": 1,
      "test_tuning": {
        "jest_max_workers": 2
      }
    },
    "orm": {
      "codegen_before_typecheck": [
        "npx prisma generate"
      ],
      "display_name": "Prisma",
      "id": "prisma",
      "kind": "orm",
      "migrate_deploy": "npx prisma migrate deploy",
      "prompt_fragment": "stacks/enterprise/db_agent.md",
      "schema_file_candidates": [
        "prisma/schema.prisma",
        "backend/prisma/schema.prisma"
      ],
      "schema_version": 1,
      "seed_path_candidates": [
        "prisma/seed/seed.js",
        "prisma/seed.js",
        "backend/prisma/seed/seed.js",
        "backend/prisma/seed.js"
      ]
    }
  },
  "display_name": "Next.js Fullstack (App Router + API routes + Prisma)",
  "docker_targets": [
    {
      "context": ".",
      "dockerfile": "Dockerfile",
      "label": "app"
    }
  ],
  "glue": {
    "api_client": "fetch",
    "auth_pattern": "jwt_session",
    "frontend_api_base": "/api"
  },
  "known_good_dockerfiles": true,
  "notes": "First no-separate-backend topology: Next.js API routes serve the backend role (frontend component declares backend_role=api_routes; no 'backend' component on purpose). Single serve process, single docker target. Seed MUST emit SEED_CREDS_JSON (template-level contract).",
  "resolved_schema_version": 1,
  "schema_version": 1,
  "serve_topology": "single_next_server",
  "stack_id": "nextjs-fullstack",
  "template_dir": "template-nextjs-fullstack"
}
