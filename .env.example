# DATABASE_URL: PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app?schema=public"

# JWT_SECRET: HS256 signing secret for session tokens (lib/auth.ts). App should
# fail fast in production if this is unset — do not ship the dev default.
JWT_SECRET="dev-secret"

# SEED_SECRET: used to derive deterministic demo credentials in prisma/seed.ts.
SEED_SECRET="colossus-seed"

# PORT: port the Next.js server listens on (next start / standalone server.js).
PORT=3000
